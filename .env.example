# =========================================================================
# ChubbAgent configuration. Copy to `.env` and fill in secrets.
# All variables are prefixed with CHUBB_ and map to chubb_ci/config/settings.py
# =========================================================================

# --- LLM provider (provider-agnostic, OpenAI-compatible) -----------------
# Swapping provider = change these values only, no code change.
# Presets available: deepseek | glm | qwen | openai  (see chubb_ci/llm/providers.py)
CHUBB_LLM_PROVIDER=deepseek
CHUBB_LLM_API_KEY=sk-your-deepseek-key-here
# Leave base_url / models empty to use the provider preset defaults.
# CHUBB_LLM_BASE_URL=https://api.deepseek.com
# CHUBB_LLM_EXTRACT_MODEL=deepseek-chat
# CHUBB_LLM_DAILY_MODEL=deepseek-chat
# CHUBB_LLM_WEEKLY_MODEL=deepseek-reasoner

# Rough price for cost estimation (CNY per 1M tokens). Defaults suit deepseek-chat.
# CHUBB_LLM_PRICE_INPUT_PER_M=1.0
# CHUBB_LLM_PRICE_OUTPUT_PER_M=2.0

# --- Storage & paths -----------------------------------------------------
# CHUBB_DATA_DIR=data
# CHUBB_DB_URL=sqlite:///data/chubb_ci.db

# --- Crawler -------------------------------------------------------------
# CHUBB_REQUEST_TIMEOUT=30
# CHUBB_RATE_LIMIT_DELAY=2.0
# CHUBB_MAX_RETRIES=3
# CHUBB_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 ...

# --- Scheduler (cron syntax: min hour day month day_of_week) -------------
# Daily short digest at 02:30 (off-peak = cheaper DeepSeek tokens).
# CHUBB_DAILY_CRON=30 2 * * *
# Weekly detailed report Monday 03:00.
# CHUBB_WEEKLY_CRON=0 3 * * 1
# CHUBB_TIMEZONE=Asia/Shanghai
